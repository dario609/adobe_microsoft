# Blank Canvas Mode Configuration Template

# ===== Blank Canvas Dimensions =====
# Set canvas size for blank mode (default: 1080x1920 for mobile)
VITE_BLANK_CANVAS_WIDTH=1080
VITE_BLANK_CANVAS_HEIGHT=1920

# Optional: Initial asset URL to inject on blank canvas creation
# Leave empty to start with empty canvas
VITE_BLANK_INITIAL_ASSET_URL=

# ===== Adobe Express Config =====
VITE_ADOBE_CLIENT_ID=your-client-id-here
VITE_ADOBE_APP_NAME=your-app-name

# ===== Session Settings =====
# Session duration in seconds (default: 300 = 5 minutes)
VITE_SESSION_SECONDS=300

# Show session timer to users (default: true)
VITE_SHOW_SESSION_TIMER=true

# ===== Feature Flags =====
# Enable blank canvas mode globally
BLANK_MODE_ENABLED=true

# Enable blank canvas as option in gallery (for hybrid mode)
GALLERY_ENABLE_BLANK_OPTION=true

# ===== Branding =====
VITE_BRAND_NAME=Kiosk for Adobe Express

# ===== Optional: Fallback Canvas Settings =====
# Used if blank canvas dimensions not provided
VITE_FALLBACK_CANVAS_WIDTH=1080
VITE_FALLBACK_CANVAS_HEIGHT=1920

# ===== Optional: Asset Import Settings =====
# Max image size for import (bytes)
VITE_MAX_ASSET_SIZE=10485760

# Asset import timeout (milliseconds)
VITE_ASSET_IMPORT_TIMEOUT=15000

# ===== Server Settings =====
# API base URL
VITE_API_BASE_URL=http://localhost:3000

# Upload endpoint (relative to API base)
VITE_UPLOAD_ENDPOINT=/api/upload

# ===== Admin Settings =====
# Password for admin panel (optional)
VITE_ADMIN_PASSWORD=

# ===== Development =====
# Log debug information
VITE_DEBUG=false

# ===== Examples =====

# Example 1: Standard Blank Mode (Mobile-portrait)
# VITE_BLANK_CANVAS_WIDTH=1080
# VITE_BLANK_CANVAS_HEIGHT=1920
# BLANK_MODE_ENABLED=true

# Example 2: Desktop Size
# VITE_BLANK_CANVAS_WIDTH=1920
# VITE_BLANK_CANVAS_HEIGHT=1080

# Example 3: With Initial Template
# VITE_BLANK_CANVAS_WIDTH=1080
# VITE_BLANK_CANVAS_HEIGHT=1920
# VITE_BLANK_INITIAL_ASSET_URL=https://cdn.example.com/templates/brand-template.jpg

# Example 4: Hybrid (Gallery + Blank Option)
# GALLERY_ENABLE_BLANK_OPTION=true
# VITE_BLANK_CANVAS_WIDTH=1080
# VITE_BLANK_CANVAS_HEIGHT=1920
